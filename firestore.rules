rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function userRole() {
      return getUserData().role;
    }
    function isOwner() {
      return isSignedIn() && request.auth.token.email == "wjohnston.media@gmail.com";
    }
    function isAdmin() {
      return isSignedIn() && userRole() in ['Admin', 'Master Admin', 'Owner'];
    }
    function isMasterAdminOrOwner() {
      return isSignedIn() && userRole() in ['Master Admin', 'Owner'];
    }
    function isNotBlocked() {
      return !getUserData().blocked;
    }

    // ─── Users ─────────────────────────────────────────
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (
        (request.auth.uid == uid && !('role' in request.resource.data.diff(resource.data).affectedKeys())) ||
        (isAdmin() && resource.data.email != "wjohnston.media@gmail.com") ||
        isOwner()
      );
      allow delete: if isMasterAdminOrOwner() && resource.data.email != "wjohnston.media@gmail.com";
    }

    // ─── Site settings ─────────────────────────────────
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Portfolio ─────────────────────────────────────
    // Old path — kept for backwards compatibility
    match /portfolio/{category}/items/{item} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // New project-based path
    match /portfolio/{category}/projects/{project} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Messages ──────────────────────────────────────
    match /messages/{msgId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ─── Pending Clients ───────────────────────────────
    match /pendingClients/{email} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      allow delete: if isSignedIn();
    }

    // ─── Quotes ────────────────────────────────────────
    match /quotes/{quoteId} {
      allow create: if isSignedIn() && isNotBlocked();
      allow read: if isSignedIn() && (
        resource.data.clientId == request.auth.uid || isAdmin()
      );
      allow update: if isAdmin() || (
        isSignedIn() &&
        resource.data.clientId == request.auth.uid &&
        request.resource.data.status == 'Accepted' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'acceptedAt'])
      );
      allow delete: if isAdmin();
    }

    // ─── Client Projects ───────────────────────────────
    match /projects/{projectId} {
      allow read: if isSignedIn() && (
        resource.data.clientId == request.auth.uid || isAdmin()
      );
      allow create: if isAdmin();
      allow update: if isAdmin() || (
        isSignedIn() &&
        resource.data.clientId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['clientNote', 'clientNoteUpdatedAt'])
      );
      allow delete: if isMasterAdminOrOwner();
    }
  }
}
