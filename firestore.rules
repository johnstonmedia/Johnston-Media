rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ──────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function userRole() {
      return getUserData().role;
    }
    function isOwner() {
      return isSignedIn() && request.auth.token.email == "wjohnston.media@gmail.com";
    }
    function isAdmin() {
      return isSignedIn() && userRole() in ['Admin', 'Master Admin', 'Owner'];
    }
    function isMasterAdminOrOwner() {
      return isSignedIn() && userRole() in ['Master Admin', 'Owner'];
    }
    function isClient() {
      return isSignedIn() && userRole() in ['Client', 'Admin', 'Master Admin', 'Owner'];
    }
    function isNotBlocked() {
      return !getUserData().blocked;
    }

    // ─── Users collection ──────────────────────────────
    match /users/{uid} {
      // Anyone can read their own profile
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());

      // Create own profile on signup
      allow create: if isSignedIn() && request.auth.uid == uid;

      // Update own profile (limited fields), or admin updating others
      allow update: if isSignedIn() && (
        // User updating their own non-role fields
        (request.auth.uid == uid && !('role' in request.resource.data.diff(resource.data).affectedKeys())) ||
        // Admin can update role, but not owner email
        (isAdmin() && resource.data.email != "wjohnston.media@gmail.com") ||
        // Owner can update anything except remove owner from owner email
        isOwner()
      );

      // Only Master Admin / Owner can delete users (not owner email)
      allow delete: if isMasterAdminOrOwner() && resource.data.email != "wjohnston.media@gmail.com";
    }

    // ─── Site settings ─────────────────────────────────
    match /settings/{doc} {
      allow read: if true; // Public read for homepage to load settings
      allow write: if isAdmin();
    }

    // ─── Portfolio ─────────────────────────────────────
    match /portfolio/{category}/items/{item} {
      allow read: if true; // Public
      allow write: if isAdmin();
    }

    // ─── Messages (contact form) ────────────────────────
    match /messages/{msgId} {
      allow create: if true; // Anyone can send a contact message
      allow read, update, delete: if isAdmin();
    }

    // ─── Quotes ────────────────────────────────────────
    match /quotes/{quoteId} {
      // Clients/Prospective can create and read their own quotes
      allow create: if isSignedIn() && isNotBlocked();
      allow read: if isSignedIn() && (
        resource.data.clientId == request.auth.uid || isAdmin()
      );
      allow update, delete: if isAdmin();
    }

    // ─── Projects ──────────────────────────────────────
    match /projects/{projectId} {
      // Clients can read their own projects
      allow read: if isSignedIn() && (
        resource.data.clientId == request.auth.uid || isAdmin()
      );
      allow create, update: if isAdmin();
      allow delete: if isMasterAdminOrOwner();
    }
  }
}
