rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role
        in ['Admin', 'Master Admin', 'Owner'];
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isReasonableSize() {
      return request.resource.size < 500 * 1024 * 1024; // 500MB max
    }

    // Hero video — admin only, 500MB max
    match /hero/{file} {
      allow read: if true;
      allow write: if isAdmin() && isReasonableSize();
    }

    // Portfolio assets and clips — admin only
    match /portfolio/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isReasonableSize();
    }

    // Client logos for banner — admin only
    match /clientLogos/{file} {
      allow read: if true;
      allow write: if isAdmin() && isReasonableSize();
    }

    // Project delivery files — admin uploads, signed-in clients can read
    match /projects/{projectId}/{file} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isReasonableSize();
    }
  }
}
