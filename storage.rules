rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role
        in ['Admin', 'Master Admin', 'Owner'];
    }

    // Hero video — admin only write, public read
    match /hero/{file} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Portfolio assets — admin only write, public read
    match /portfolio/{category}/{file} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Project delivery files — admin write, client read (checked via Firestore)
    match /projects/{projectId}/{file} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
